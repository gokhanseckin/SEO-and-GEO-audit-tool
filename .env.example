# Supabase (from Studio → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Serper.dev API key (https://serper.dev)
SERPER_API_KEY=

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Google PageSpeed Insights API key (optional, raises quota)
PAGESPEED_API_KEY=

# App URL — http://localhost:3000 for dev; production URL once deployed
APP_URL=http://localhost:3000

# Default Serper cap per audit (1-20)
SERPER_QUERY_CAP_DEFAULT=15
